{
  "headers": [
    {
      "source": "/basis/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/basis/(.*\\.wasm)",
      "headers": [
        { "key": "Content-Type", "value": "application/wasm" }
      ]
    }
  ],
  "functions": {
    "src/app/api/xtts-tts/route.ts": {
      "maxDuration": 300
    },
    "src/app/api/admin/upload-wav/route.ts": {
      "maxDuration": 120
    }
  }
}
