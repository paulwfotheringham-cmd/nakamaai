# Simli realtime avatar — SERVER ONLY (never NEXT_PUBLIC_SIMLI_API_KEY)
# The browser calls /api/simli/session; only that route reads SIMLI_API_KEY.
# Create key: https://www.simli.com/ → Dashboard → API Keys
SIMLI_API_KEY=

# OpenAI — preferred for /live-test: gpt-4o-mini stream + onyx TTS (server-side only)
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Fallback when OPENAI_API_KEY is unset (already on Vercel for this project):
# GROQ_API_KEY=          → chat via llama-3.3-70b-versatile
# CARTESIA_API_KEY=      → TTS for /live-test when OPENAI_API_KEY is unset (PCM 16kHz for Simli)
# Optional overrides (must be full UUIDs — leave unset rather than empty strings):
# CARTESIA_VOICE_DONNY=  CARTESIA_PREVIEW_DONNY_ID=
# CARTESIA_VOICE_CLINT=  CARTESIA_PREVIEW_CLINT_ID=
# CARTESIA_VOICE_DAMON=  CARTESIA_PREVIEW_DAMON_ID=
SIMLI_FACE_ID=5514e24d-6086-46a3-ace4-6a7264e5cb7c
# Optional: unique face per onboarding guide (from app.simli.com)
SIMLI_FACE_FRANK=5514e24d-6086-46a3-ace4-6a7264e5cb7c
SIMLI_FACE_MARCUS=6ebf0aa7-6fed-443d-a4c6-fd1e3080b215
SIMLI_FACE_CLINT=101bef0d-b62d-4fbe-a6b4-89bc3fc66ec6
SIMLI_FACE_SIENNA=4145d354-fd78-4c29-b6b1-0663a04e8d7b

# Canonical public site URL
# Production: https://nakamanights.com
NEXT_PUBLIC_SITE_URL=https://nakamanights.com

# /admin WAV uploads — paste same value in the Admin page “Admin key” field
ADMIN_UPLOAD_SECRET=

# create-audio-test page: use XTTS proxy routes instead of Cartesia
# NEXT_PUBLIC_TTS_BACKEND=xtts

# ─── XTTS (Runpod / self-hosted) ─────────────────────────────────────────────
# Public HTTPS base URL of your XTTS container (no trailing slash).
# Example Runpod: https://YOUR_POD_ID-8000.proxy.runpod.net
XTTS_SERVER_URL=

# Optional: defaults shown
# XTTS_TTS_PATH=/tts
# XTTS_VOICE_FIELD=voice_id
# XTTS_API_KEY=
# XTTS_NGROK_BYPASS=1

# Optional: override voice list for /api/xtts-voices (JSON array of voice objects with id, name, description, language, gender, accent, age, is_public)
# XTTS_VOICES_JSON=[]
