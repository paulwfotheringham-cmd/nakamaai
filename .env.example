# Copy to .env.local (not committed).

# Canonical public site URL (no trailing slash). Used for auth redirects and metadata.
# Production: https://nakamanights.com
NEXT_PUBLIC_SITE_URL=https://nakamanights.com

# /admin WAV uploads — paste same value in the Admin page “Admin key” field
ADMIN_UPLOAD_SECRET=

# create-audio-test page: use XTTS proxy routes instead of Cartesia
# NEXT_PUBLIC_TTS_BACKEND=xtts

# ─── XTTS (Runpod / self-hosted) ─────────────────────────────────────────────
# Public HTTPS base URL of your XTTS container (no trailing slash).
# Example Runpod: https://YOUR_POD_ID-8000.proxy.runpod.net
XTTS_SERVER_URL=

# Optional: defaults shown
# XTTS_TTS_PATH=/tts
# XTTS_VOICE_FIELD=voice_id
# XTTS_API_KEY=
# XTTS_NGROK_BYPASS=1

# Optional: override voice list for /api/xtts-voices (JSON array of voice objects with id, name, description, language, gender, accent, age, is_public)
# XTTS_VOICES_JSON=[]
